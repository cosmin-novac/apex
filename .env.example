# Apex environment variables
# Copy this file to .env and fill in your values.

# Runtime
DASH_DEBUG=1
DASH_USE_RELOADER=0
PORT=8888
APEX_LOG_LEVEL=INFO
# Public Yahoo/yfinance price cache for backtesting. Defaults to ~/.apex/asset_cache.
# On Azure App Service, the default home directory is fine; override only if needed.
# APEX_ASSET_CACHE_DIR=/home/data/asset_cache

# AI-assisted backtesting rule generation
OPENAI_API_KEY=

# Trade Republic portfolio sync credential encryption
TR_ENCRYPTION_KEY=generate-a-random-32-char-string
# Current pytr web login needs an AWS WAF token. Use "playwright" to match
# app.traderepublic.com closely; do not silently fall back to older auth flows.
TR_WAF_TOKEN_METHOD=playwright

# Apex runs as a standalone, single-user app: no sign-in and no cloud storage.
# Synced portfolio data lives only in the browser (encrypted localStorage) and
# the local pytr cache. There is no external identity or data dependency.
