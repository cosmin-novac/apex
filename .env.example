# Apex environment variables
# Copy this file to .env and fill in your values.

# Runtime
DASH_DEBUG=1
DASH_USE_RELOADER=0
PORT=8888
APEX_LOG_LEVEL=INFO

# AI-assisted backtesting rule generation
OPENAI_API_KEY=

# Trade Republic portfolio sync credential encryption
TR_ENCRYPTION_KEY=generate-a-random-32-char-string
# Current pytr web login needs an AWS WAF token. Use "playwright" to match
# app.traderepublic.com closely; do not silently fall back to older auth flows.
TR_WAF_TOKEN_METHOD=playwright

# ── Authentication (Clerk) ──────────────────────────────────────────────
# Dedicated Apex Clerk instance. The publishable key is public (embedded in the
# page); the secret key stays server-side. CLERK_PUBLISHABLE_KEY and the
# NEXT_PUBLIC_ alias are interchangeable.
CLERK_PUBLISHABLE_KEY=pk_test_YXNzdXJlZC1rYW5nYXJvby0wLmNsZXJrLmFjY291bnRzLmRldiQ
CLERK_SECRET_KEY=sk_test_your_secret_here

# ── Per-user encrypted storage (Azure Blob) ─────────────────────────────
# Storage account in the apex-rg resource group. Each user's data is stored as
# one Fernet-encrypted blob at users/{uid}.enc in the 'apex-data' container.
AZURE_STORAGE_CONNECTION_STRING=
# Optional: override the container name (default: apex-data)
# APEX_BLOB_CONTAINER=apex-data
# Master key for per-user encryption: base64-encoded 32 bytes.
# Generate with:  python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
# WARNING: if this key is lost, all encrypted user blobs are unrecoverable.
APEX_ENCRYPTION_KEY=
